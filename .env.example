# ─── Trading Agent Environment Configuration ─────────────────────────────────

# Trading Mode: 'paper' for simulation, 'live' for real trading
TRADING_MODE=paper

# Starting balance for paper trading
INITIAL_BALANCE=10000

# Symbols to trade (comma-separated)
SYMBOLS=BTC-USD,ETH-USD,SOL-USD

# Risk management
MAX_POSITION_SIZE=0.15    # Max 15% of portfolio in single position
RISK_PER_TRADE=0.02       # Risk max 2% per trade

# Agent behavior
IMPROVEMENT_CYCLE=10      # Self-improve after every N trades
DECISION_INTERVAL=60000   # Make decisions every 60 seconds (milliseconds)

# Dashboard
DASHBOARD_PORT=3000

# ─── LIVE TRADING ONLY ────────────────────────────────────────────────────────
# WARNING: Real money at risk! Only set these after thorough paper trading.
# Get keys from: https://www.coinbase.com/settings/api
# Required scopes: wallet:accounts:read, wallet:transactions:send

# COINBASE_API_KEY=your_api_key_name_here
# COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nyour_key_here\n-----END EC PRIVATE KEY-----

# ─── MCP Server Config (optional) ────────────────────────────────────────────
# MCP_SERVER_URL=https://mcp.coinbase.com/sse
